<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User List</title>
    <style>
        /* CSS giúp kẻ bảng và làm đẹp */
        table, th, td {
            border: 1px solid black; /* Kẻ viền đen 1px */
            border-collapse: collapse; /* Gộp các viền thừa lại với nhau */
        }
        th, td {
            padding: 10px; /* Tạo khoảng trống cho chữ dễ nhìn */
            text-align: left; /* Căn trái nội dung */
        }
        th {
            background-color: #f2f2f2; /* Tô màu nền xám nhạt cho hàng tiêu đề */
        }
    </style>
</head>
<body>
    <table style="width:100%">
        <tr>
            <th>Email</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Address</th>
            <th>Action</th>
        </tr>
        <% for(let i=0; i < datalist.length; i++) { %>
        <tr>
            <td><%= datalist[i].email %></td>
            <td><%= datalist[i].firstName %></td>
            <td><%= datalist[i].lastName %></td>
            <td><%= datalist[i].address %></td>
            <td>
                <a href="/edit-crud?id=<%= datalist[i].id %>">Edit</a> || 
                <a href="/delete-crud?id=<%= datalist[i].id %>">Delete</a>
            </td>
        </tr>
        <% } %>
    </table>
</body>
</html>